# Future reference-gateway sketch. Never commit a real .env.
# Current release is CLI-only and needs no environment variables.
# Do not copy this file for the normal `ash run`, `ash compare`, or
# `ash validate` workflow; those commands ignore these values.

GATEWAY_PORT=8080
GATEWAY_DB_URL=sqlite:///gateway.db
GATEWAY_ADMIN_TOKEN=change-me

# Upstream provider (credentials stay on the gateway, never returned to clients)
GATEWAY_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# Optional features
# GATEWAY_REDIS_URL=redis://localhost:6379/0
# GATEWAY_CLASSIFIER_ENABLED=false
# GATEWAY_CLASSIFIER_MODEL=
# GATEWAY_POLICY_PATH=app/config/policies/default.yaml

GATEWAY_LOG_LEVEL=INFO
