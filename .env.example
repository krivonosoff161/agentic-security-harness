# Copy to .env and fill in. Never commit .env.
# Server settings apply from v0.2+. v0.1 is CLI-only and needs none of these.

GATEWAY_PORT=8080
GATEWAY_DB_URL=sqlite:///gateway.db
GATEWAY_ADMIN_TOKEN=change-me

# Upstream provider (credentials stay on the gateway, never returned to clients)
GATEWAY_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# Optional features
# GATEWAY_REDIS_URL=redis://localhost:6379/0     # cache/budgets (v0.4)
# GATEWAY_CLASSIFIER_ENABLED=false               # LLM threat classifier (v0.5)
# GATEWAY_CLASSIFIER_MODEL=
# GATEWAY_POLICY_PATH=app/config/policies/default.yaml

GATEWAY_LOG_LEVEL=INFO
